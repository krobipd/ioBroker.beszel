{
  "type": "tabs",
  "i18n": true,
  "items": {
    "tab_connection": {
      "type": "panel",
      "label": "tab_connection",
      "items": {
        "url": {
          "type": "text",
          "label": "label_url",
          "help": "help_url",
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 8,
          "xl": 8
        },
        "pollInterval": {
          "type": "number",
          "label": "label_pollInterval",
          "help": "help_pollInterval",
          "min": 10,
          "max": 300,
          "default": 60,
          "xs": 12,
          "sm": 12,
          "md": 2,
          "lg": 2,
          "xl": 2
        },
        "requestTimeout": {
          "type": "number",
          "label": "label_requestTimeout",
          "help": "help_requestTimeout",
          "min": 5,
          "max": 120,
          "default": 15,
          "xs": 12,
          "sm": 12,
          "md": 2,
          "lg": 2,
          "xl": 2
        },
        "username": {
          "type": "text",
          "label": "label_username",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "password": {
          "type": "password",
          "label": "label_password",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "checkConnection": {
          "type": "sendTo",
          "command": "checkConnection",
          "jsonData": "{\"url\": \"${data.url}\", \"username\": \"${data.username}\", \"password\": \"${data.password}\"}",
          "label": "btn_checkConnection",
          "result": {
            "okText": "msg_connectionOk",
            "errorText": "msg_connectionFailed"
          },
          "xs": 12,
          "sm": 12,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "_supportHeader": {
          "newLine": true,
          "type": "header",
          "text": "supportHeader",
          "size": 5
        },
        "_aboutInfo": {
          "type": "staticText",
          "text": "aboutInfo",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "style": {
            "fontSize": 14,
            "marginBottom": 16
          }
        },
        "_kofiLink": {
          "type": "staticLink",
          "href": "https://ko-fi.com/krobipd",
          "label": "donateKofi",
          "button": true,
          "variant": "outlined",
          "color": "primary",
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "_paypalLink": {
          "type": "staticLink",
          "href": "https://paypal.me/krobipd",
          "label": "donatePaypal",
          "button": true,
          "variant": "outlined",
          "color": "primary",
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        }
      }
    },
